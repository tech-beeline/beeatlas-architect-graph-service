{
    "name": "Maven DevContainer",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/app",
    "postCreateCommand": "mvn clean install", // Команда, выполняемая после создания контейнера
    "customizations": {
        "vscode": {
            "settings": {
                "java.home": "/usr/local/openjdk-17" // Указываем путь к Java 17
            },
            "extensions": [
                "vscjava.vscode-java-pack", // Расширения для Java
                "pivotal.vscode-spring-boot", // Расширение для Spring Boot
                "vscjava.vscode-maven" // Расширение для Maven
            ]
        }
    }
}